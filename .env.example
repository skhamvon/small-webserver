# Port du serveur Node (static + throttle)
PORT=5000

# Débit max en kilo-octets/seconde (0 = pas de limitation).
# Ordres de grandeur indicatifs pour la simulation (réel très variable) :
#   ~25   — 2G / EDGE
#   ~200  — 3G
#   ~2500 — 4G LTE (bon signal)
#   ~8000 — 5G (gros débit) ou 0 pour « sans limite »
#   ~500  — ADSL classique (quelques Mbit/s)
#   ~4000 — VDSL / fibre entrée de gamme (ordre de grandeur)
THROTTLE_KBPS=0

# URL du remote Module Federation (dev). Pour la solution A/B réelle (modale simulation, etc.) :
#   http://localhost:5001/remoteEntry.js   ← apps/remote d’abtest-solution (pas de préfixe /remote/)
# Stub MF minimal du dépôt small-webserver seul :
#   http://localhost:5101/remote/remoteEntry.js
VITE_ABTEST_REMOTE_URL=http://localhost:5001/remoteEntry.js

# API abtest-solution (évaluation campagnes) — requise pour la démo « backend »
# ABTEST_API_URL=http://127.0.0.1:5002
# ABTEST_BACKEND_DEMO_CAMPAIGN_ID=10003

# Ports personnalisables (facultatifs) pour les dev/déploiements
# VITE_HOST_PORT=5173
# VITE_ABTEST_REMOTE_PORT=5101

# Exposition réseau des dev servers Vite (Docker / hostname, défaut : host=true).
# VITE_DEV_BIND_ALL=false
# VITE_DEV_ALLOWED_HOSTS=gw2sdev-docker.ovh.net,localhost
# Accès navigateur via hostname (remplacer localhost dans les URL ci-dessus) :
# VITE_ABTEST_REMOTE_URL=http://gw2sdev-docker.ovh.net:43107/remoteEntry.js
