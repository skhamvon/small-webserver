# Port du serveur Node (static + throttle)
PORT=3000

# Débit max en kilo-octets/seconde (0 = pas de limitation).
# Ordres de grandeur indicatifs pour la simulation (réel très variable) :
#   ~25   — 2G / EDGE
#   ~200  — 3G
#   ~2500 — 4G LTE (bon signal)
#   ~8000 — 5G (gros débit) ou 0 pour « sans limite »
#   ~500  — ADSL classique (quelques Mbit/s)
#   ~4000 — VDSL / fibre entrée de gamme (ordre de grandeur)
THROTTLE_KBPS=0

# URL du remote Module Federation (dev: serveur Vite du remote)
VITE_ABTEST_REMOTE_URL=http://localhost:5001/remote/remoteEntry.js
